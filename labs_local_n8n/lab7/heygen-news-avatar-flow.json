        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ video_inputs: [ { character: { type: 'talking_photo', talking_photo_id: $('Generate Webhook').item.json.body.talking_photo_id || '6269abc2c2c04fe4be8f45a24f26f043', scale: 1 }, voice: { type: 'text', input_text: $('Write Script (Ollama)').item.json.output, voice_id: '5d8c378ba8c3434586081a52ac368738', speed: 1.05 } } ], dimension: { width: 1920, height: 1080 } }) }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        160,
