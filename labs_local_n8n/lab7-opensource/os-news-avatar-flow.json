    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.body.topic || 'FIFA World Cup 2026 Round of 16 \u2014 latest results and what happens next' }}",
        "options": {
          "systemMessage": "You are a TV sports news scriptwriter. Write a short, energetic news-anchor script about the given topic that runs about 20 seconds when read aloud (roughly 55-70 words).\n\nRules:\n- Output ONLY the words the anchor speaks \u2014 one flowing paragraph.\n- No stage directions, no timestamps, no camera notes, no speaker labels, no markdown, no surrounding quotation marks.\n- Start with a warm welcome, deliver the key update with excitement, and end with a hook to keep watching.\n- Keep it broadcast-natural and easy to say aloud."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -96,
        0
      ],
      "id": "a2222222-2222-4222-8222-222222222222",
      "name": "Write Script (Ollama)"
    },
    {
      "parameters": {
        "model": "gemma4:latest",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "typeVersion": 1,
      "position": [
        -96,
        208
      ],
      "id": "a3333333-3333-4333-8333-333333333333",
      "name": "Ollama Chat Model",
      "credentials": {
        "ollamaApi": {
          "id": "E2TBIVWPZ64avN7z",
          "name": "Ollama local"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8099/render",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ text: $json.output }) }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          },
          "timeout": 300000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        160,
        0
      ],
      "id": "a4444444-4444-4444-8444-444444444444",
      "name": "Local Render (say + ffmpeg)"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { video_url: $json.video_path ? ('http://localhost:8099' + $json.video_path) : null, engine: $json.engine || null, duration: $json.duration || null, script: $('Write Script (Ollama)').item.json.output, error: $json.error || null } }}",
        "options": {}
      },
