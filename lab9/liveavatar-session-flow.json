        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ avatar_id: $json.body.avatar_id || '513fd1b7-7ef9-466d-9af2-344e51eeb833', context_id: $json.body.context_id || '16649c93-338e-4dac-8540-937bcf441fad', orientation: $json.body.orientation || 'horizontal' }) }}",
