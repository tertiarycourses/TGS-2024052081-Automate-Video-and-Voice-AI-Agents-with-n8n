      "name": "LiveAvatar: Create Embed",
      "credentials": {
        "httpHeaderAuth": {
          "id": "56DfJTVwM2VXyfkP",
          "name": "LiveAvatar API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// The website gets a short-lived EMBED URL \u2014 never the API key. Same rule as the\n// Retell and Veo labs: the secret lives in n8n, the browser gets a ticket.\nconst r = $input.first().json;\nconst d = r.data || {};\n\nif (!d.url) {\n  return [{ json: {\n    ok: false,\n    error: r.message || 'LiveAvatar did not return an embed URL. Check the API key and the avatar id.',\n  } }];\n}\n\nreturn [{ json: {\n  ok: true,\n  embed_id: d.embed_id,\n  url: d.url,\n  orientation: d.orientation,\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ],
      "id": "f0000004-0000-4000-8000-000000000004",
      "name": "Build Response"
    },
    {
      "parameters": {
        "options": {}
      },
