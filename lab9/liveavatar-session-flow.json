      "id": "f0000008-0000-4000-8000-000000000008",
      "name": "LiveAvatar: List Contexts",
      "credentials": {
        "httpHeaderAuth": {
          "id": "56DfJTVwM2VXyfkP",
          "name": "LiveAvatar API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// A context is the avatar's PERSONA (its prompt + knowledge). The learner picks one\n// on the page, so they can see the same face behave like a coach or a recruiter.\nconst rows = ($input.first().json.data || {}).results || [];\nreturn [{ json: { contexts: rows.map((c) => ({ id: c.id, name: c.name })) } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
